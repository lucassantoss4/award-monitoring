# ============================================
# Award Monitoring - Configuração de Ambiente
# ============================================
# Copie este arquivo para .env e preencha os valores:
#   cp .env.example .env

# --- SEGURANÇA ---
# Chave secreta do Flask (gere uma com: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY="substitua-por-uma-chave-segura"

# Chave de autenticação para endpoints de automação (header: X-API-KEY)
API_KEY="substitua-por-uma-chave-de-api"

# --- NOTIFICAÇÕES POR E-MAIL ---
# Destinatários do e-mail de alertas (separados por ;)
EMAIL_DESTINATARIOS="seu-email@exemplo.com"

# Cópia (CC) dos e-mails (opcional)
EMAIL_COPIA=""

# --- POWER AUTOMATE (Opcional) ---
# URL do webhook para integração com Power Automate
POWER_AUTOMATE_WEBHOOK_URL=""
